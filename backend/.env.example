# ─── FairLens Environment Configuration ───────────────
# Copy this to .env and fill in your values

# App
FAIRLENS_APP_ENV=development
FAIRLENS_APP_NAME=FairLens API

# Database (SQLite for dev, PostgreSQL for prod)
# FAIRLENS_DATABASE_URL=sqlite+pysqlite:///./fairlens.db
# FAIRLENS_DATABASE_URL=postgresql+psycopg2://fairlens:password@localhost:5432/fairlens

# Auth (set to false in production)
FAIRLENS_AUTH_DISABLED=true
FAIRLENS_JWT_SECRET_KEY=CHANGE-ME-use-openssl-rand-hex-32

# Gemini AI
FAIRLENS_GEMINI_API_KEY=
FAIRLENS_GEMINI_MODEL=gemini-1.5-flash

# Celery (comment out for BackgroundTasks fallback)
# FAIRLENS_CELERY_BROKER_URL=redis://localhost:6379/0

# CORS
FAIRLENS_CORS_ORIGINS=["http://localhost:5173"]

# Limits
FAIRLENS_MAX_UPLOAD_SIZE_MB=50
FAIRLENS_RATE_LIMIT_DEFAULT=100/minute
FAIRLENS_RATE_LIMIT_PROBE=10/minute
FAIRLENS_RATE_LIMIT_WEBHOOK=1000/minute
