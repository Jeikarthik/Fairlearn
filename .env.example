# ─────────────────────────────────────────────────
# FairLens Environment Configuration
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────────

# ── App ──────────────────────────────────────────
FAIRLENS_APP_ENV=development
# FAIRLENS_APP_ENV=production

# ── Database ─────────────────────────────────────
# Local dev (SQLite — no setup needed):
# FAIRLENS_DATABASE_URL=sqlite+pysqlite:///./fairlens.db
#
# Production (PostgreSQL):
# FAIRLENS_DATABASE_URL=postgresql+psycopg2://fairlens:your_password@localhost:5432/fairlens
#
# Docker Compose (auto-set, don't change):
# FAIRLENS_DATABASE_URL=postgresql+psycopg2://fairlens:fairlens_secret@postgres:5432/fairlens

# ── Gemini AI (required for AI-generated reports) ─
FAIRLENS_GEMINI_API_KEY=
FAIRLENS_GEMINI_MODEL=gemini-1.5-flash

# ── Celery (optional — background task processing) ─
# Leave empty to use FastAPI BackgroundTasks (simpler, no Redis needed)
# Set to Redis URL for production multi-worker processing:
# FAIRLENS_CELERY_BROKER_URL=redis://localhost:6379/0

# ── Storage ──────────────────────────────────────
FAIRLENS_UPLOAD_DIR=../uploads
FAIRLENS_REPORTS_DIR=../reports
FAIRLENS_MAX_UPLOAD_SIZE_MB=50

# ── CORS ─────────────────────────────────────────
FAIRLENS_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Auth (disable for local dev) ─────────────────
FAIRLENS_AUTH_DISABLED=true
FAIRLENS_JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Rate Limiting ────────────────────────────────
FAIRLENS_RATE_LIMIT_DEFAULT=100/minute
FAIRLENS_RATE_LIMIT_PROBE=10/minute

# ── Docker Compose Only ──────────────────────────
# Set this in your shell before running docker compose:
# export GEMINI_API_KEY=your_actual_key
